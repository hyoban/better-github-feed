{
  "name": "web",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vp run db:migrate:local && vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "type-check": "tsgo",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "deploy": "node ./scripts/deploy.mjs",
    "cf-typegen": "wrangler types ../../worker-configuration.d.ts"
  },
  "cloudflare": {
    "bindings": {
      "DB": {
        "description": "D1 stores users, sessions, GitHub followings, and feed items."
      },
      "BETTER_AUTH_URL": {
        "description": "The public Worker origin, without a trailing slash."
      },
      "BETTER_AUTH_SECRET": {
        "description": "Generate a stable secret with `openssl rand -base64 32`."
      },
      "BETTER_AUTH_GITHUB_CLIENT_ID": {
        "description": "Client ID from the production GitHub OAuth App."
      },
      "BETTER_AUTH_GITHUB_CLIENT_SECRET": {
        "description": "Client secret from the production GitHub OAuth App."
      }
    }
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@better-github-feed/api": "workspace:*",
    "@better-github-feed/contract": "workspace:*",
    "@better-github-feed/shared": "workspace:*",
    "@fn-sphere/filter": "catalog:",
    "@orpc/client": "catalog:",
    "@orpc/tanstack-query": "catalog:",
    "@tanstack/query-async-storage-persister": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-persist-client": "catalog:",
    "@tanstack/react-virtual": "catalog:",
    "better-auth": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "date-fns": "catalog:",
    "dompurify": "catalog:",
    "idb-keyval": "catalog:",
    "lucide-react": "catalog:",
    "nuqs": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "shadcn": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "vaul": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-github-feed/config": "workspace:*",
    "@cloudflare/vite-plugin": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "catalog:"
  }
}
