+// Persistent cross-process cache for serializable Tailwind operation results.
+import { createHash } from "node:crypto";
+import { closeSync, existsSync, mkdirSync, openSync, readFileSync, renameSync, statSync, unlinkSync, writeFileSync } from "node:fs";
+import { createRequire } from "node:module";
+import { tmpdir, userInfo } from "node:os";
+import { dirname, isAbsolute, join, parse, resolve } from "node:path";
+import { env, pid } from "node:process";
+import { pathToFileURL } from "node:url";
+const CACHE_SCHEMA = "better-tailwindcss-operation-cache-v1";
+const MAX_CACHE_ENTRIES = 5000;
+const STORES = new Map();
+const CONTEXT_STORES = new Map();
+const DIRTY_STORES = new Set();
+let flushTimer;
+process.once("exit", flushStores);
+export function withPersistentOperationCache(operation, ctx, input, callback) {
+    const store = getStore(ctx);
+    if (!store) {
+        return callback();
+    }
+    const key = digest(JSON.stringify({ operation, input }));
+    if (Object.hasOwn(store.entries, key)) {
+        debug("hit", operation);
+        return store.entries[key];
+    }
+    debug("miss", operation);
+    const value = callback();
+    store.entries[key] = value;
+    schedulePersist(store);
+    return value;
+}
+function getStore(ctx) {
+    if (env.BETTER_TAILWINDCSS_PERSISTENT_CACHE === "0" || ctx.version?.major !== 4) {
+        return;
+    }
+    const contextKey = `${ctx.tailwindConfigPath}:${JSON.stringify(ctx.version)}`;
+    const cachedContext = CONTEXT_STORES.get(contextKey);
+    if (cachedContext && contextIsFresh(cachedContext)) {
+        return cachedContext.store;
+    }
+    CONTEXT_STORES.delete(contextKey);
+    const fingerprintData = createFingerprint(ctx);
+    if (!fingerprintData) {
+        return;
+    }
+    const { dependencies, fingerprint } = fingerprintData;
+    const cachePath = join(getCacheDirectory(), `${fingerprint}.json`);
+    const existing = STORES.get(cachePath);
+    if (existing) {
+        CONTEXT_STORES.set(contextKey, createContextEntry(existing, dependencies));
+        return existing;
+    }
+    let entries = {};
+    try {
+        const parsed = JSON.parse(readFileSync(cachePath, "utf8"));
+        if (parsed.schema === CACHE_SCHEMA && parsed.entries && typeof parsed.entries === "object") {
+            entries = parsed.entries;
+        }
+    }
+    catch { }
+    const store = { entries, path: cachePath };
+    STORES.set(cachePath, store);
+    CONTEXT_STORES.set(contextKey, createContextEntry(store, dependencies));
+    return store;
+}
+function createFingerprint(ctx) {
+    const entryPoint = ctx.tailwindConfigPath;
+    if (!entryPoint || !isAbsolute(entryPoint) || !existsSync(entryPoint)) {
+        return;
+    }
+    const hash = createHash("sha256");
+    hash.update(CACHE_SCHEMA);
+    hash.update(JSON.stringify(ctx.version));
+    const dependencies = new Set();
+    hashCss(entryPoint, hash, dependencies);
+    const lockfile = findUp(dirname(entryPoint), "pnpm-lock.yaml");
+    if (lockfile) {
+        dependencies.add(lockfile);
+        hash.update(readFileSync(lockfile));
+    }
+    return { dependencies: [...dependencies], fingerprint: hash.digest("hex") };
+}
+function createContextEntry(store, dependencies) {
+    return {
+        checkedAt: Date.now(),
+        dependencies,
+        signature: dependencySignature(dependencies),
+        store
+    };
+}
+function contextIsFresh(entry) {
+    if (Date.now() - entry.checkedAt < 1000) {
+        return true;
+    }
+    entry.checkedAt = Date.now();
+    return entry.signature === dependencySignature(entry.dependencies);
+}
+function dependencySignature(dependencies) {
+    return dependencies.map(path => {
+        try {
+            const stats = statSync(path);
+            return `${path}:${stats.mtimeMs}:${stats.size}`;
+        }
+        catch {
+            return `${path}:missing`;
+        }
+    }).join("|");
+}
+function hashCss(filePath, hash, seen) {
+    const normalized = resolve(filePath);
+    if (seen.has(normalized) || !existsSync(normalized)) {
+        return;
+    }
+    seen.add(normalized);
+    const css = readFileSync(normalized, "utf8");
+    hash.update(normalized);
+    hash.update(css);
+    for (const match of css.matchAll(/@import\s+(?:url\()?\s*["']([^"']+)["']/g)) {
+        const specifier = match[1];
+        if (specifier.startsWith(".")) {
+            hashCss(resolve(dirname(normalized), specifier), hash, seen);
+            continue;
+        }
+        try {
+            const requireFromCss = createRequire(pathToFileURL(join(dirname(normalized), "__better_tailwindcss_cache__.mjs")));
+            const importedPath = requireFromCss.resolve(specifier);
+            if (importedPath.endsWith(".css")) {
+                hashCss(importedPath, hash, seen);
+            }
+        }
+        catch { }
+    }
+}
+function findUp(start, name) {
+    let current = start;
+    while (true) {
+        const candidate = join(current, name);
+        if (existsSync(candidate)) {
+            return candidate;
+        }
+        const parent = dirname(current);
+        if (parent === current || current === parse(current).root) {
+            return;
+        }
+        current = parent;
+    }
+}
+function getCacheDirectory() {
+    const configured = env.BETTER_TAILWINDCSS_PERSISTENT_CACHE_DIR;
+    if (configured) {
+        mkdirSync(configured, { mode: 0o700, recursive: true });
+        return configured;
+    }
+    let user = "unknown";
+    try {
+        user = String(userInfo().uid).replace(/[^a-zA-Z0-9_-]/g, "_");
+    }
+    catch { }
+    const directory = join(tmpdir(), `better-tailwindcss-operation-cache-${user}`);
+    mkdirSync(directory, { mode: 0o700, recursive: true });
+    return directory;
+}
+function persist(store) {
+    const lockPath = `${store.path}.lock`;
+    const lock = acquireLock(lockPath);
+    if (lock === undefined) {
+        return;
+    }
+    try {
+        try {
+            const parsed = JSON.parse(readFileSync(store.path, "utf8"));
+            if (parsed.schema === CACHE_SCHEMA && parsed.entries && typeof parsed.entries === "object") {
+                store.entries = { ...parsed.entries, ...store.entries };
+            }
+        }
+        catch { }
+        trimEntries(store.entries);
+        const temporary = `${store.path}.${pid}.${Date.now()}.tmp`;
+        writeFileSync(temporary, JSON.stringify({ schema: CACHE_SCHEMA, entries: store.entries }), { mode: 0o600 });
+        renameSync(temporary, store.path);
+    }
+    finally {
+        closeSync(lock);
+        try {
+            unlinkSync(lockPath);
+        }
+        catch { }
+    }
+}
+function schedulePersist(store) {
+    DIRTY_STORES.add(store);
+    if (flushTimer) {
+        clearTimeout(flushTimer);
+    }
+    flushTimer = setTimeout(flushStores, 250);
+    flushTimer.unref();
+}
+function flushStores() {
+    if (flushTimer) {
+        clearTimeout(flushTimer);
+        flushTimer = undefined;
+    }
+    const stores = [...DIRTY_STORES];
+    DIRTY_STORES.clear();
+    for (const store of stores) {
+        persist(store);
+    }
+}
+function trimEntries(entries) {
+    const keys = Object.keys(entries);
+    const excess = keys.length - MAX_CACHE_ENTRIES;
+    for (let index = 0; index < excess; index++) {
+        delete entries[keys[index]];
+    }
+}
+function acquireLock(lockPath) {
+    const waitBuffer = new Int32Array(new SharedArrayBuffer(4));
+    for (let attempt = 0; attempt < 100; attempt++) {
+        try {
+            return openSync(lockPath, "wx", 0o600);
+        }
+        catch (error) {
+            if (error?.code !== "EEXIST") {
+                return;
+            }
+            Atomics.wait(waitBuffer, 0, 0, 5);
+        }
+    }
+    return;
+}
+function digest(value) {
+    return createHash("sha256").update(value).digest("hex");
+}
+function debug(status, operation) {
+    if (env.BETTER_TAILWINDCSS_CACHE_DEBUG === "1") {
+        console.error(`[better-tailwindcss-cache] ${status} ${operation}`);
+    }
+}
