+// Persistent cross-process cache for serializable Tailwind operation results.
+import { createHash } from "node:crypto";
+import { join } from "node:path";
+import { env } from "node:process";
+import { getCacheDirectory, persistStore, readEntries } from "./persistent-cache/disk-store.js";
+import { createContextFingerprint } from "./persistent-cache/fingerprint.js";
+
+export const CACHE_SCHEMA = "better-tailwindcss-operation-cache-v3";
+const MAX_CACHE_ENTRIES = 5000;
+const STORES = new Map();
+const CONTEXT_STORES = new Map();
+const DIRTY_STORES = new Set();
+let flushTimer;
+process.once("exit", () => flushStores(false));
+
+export function withPersistentOperationCache(operation, ctx, input, callback) {
+    let store;
+    try {
+        store = getStore(ctx);
+    }
+    catch { }
+    if (!store) {
+        return callback();
+    }
+    const key = digest(JSON.stringify({ operation, input }));
+    const cached = store.entries[key];
+    if (cached && cached.operation === operation && isValidOperationValue(operation, cached.value, false)) {
+        debug("hit", operation);
+        return { ...cached.value, warnings: ctx.warnings };
+    }
+    if (cached) {
+        delete store.entries[key];
+    }
+    debug("miss", operation);
+    const value = callback();
+    if (isValidOperationValue(operation, value, true)) {
+        const { warnings: _warnings, ...cacheValue } = value;
+        store.entries[key] = { operation, value: cacheValue };
+        schedulePersist(store);
+    }
+    return value;
+}
+
+function getStore(ctx) {
+    if (env.BETTER_TAILWINDCSS_PERSISTENT_CACHE === "0" || ctx.version?.major !== 4) {
+        return;
+    }
+    const contextKey = JSON.stringify({
+        cwd: ctx.cwd,
+        installation: ctx.installation,
+        tailwindConfigPath: ctx.tailwindConfigPath,
+        tsconfigPath: ctx.tsconfigPath,
+        version: ctx.version
+    });
+    const cachedContext = CONTEXT_STORES.get(contextKey);
+    if (cachedContext && contextIsFresh(ctx, cachedContext)) {
+        return cachedContext.store;
+    }
+    CONTEXT_STORES.delete(contextKey);
+    const fingerprintData = createContextFingerprint(ctx, CACHE_SCHEMA);
+    const directory = getCacheDirectory();
+    if (!fingerprintData || !directory) {
+        return;
+    }
+    const { fingerprint } = fingerprintData;
+    const cachePath = join(directory, `${fingerprint}.json`);
+    let store = STORES.get(cachePath);
+    if (!store) {
+        store = { entries: readEntries(cachePath, CACHE_SCHEMA, isValidCacheEntry), failures: 0, path: cachePath };
+        STORES.set(cachePath, store);
+    }
+    CONTEXT_STORES.set(contextKey, { checkedAt: Date.now(), fingerprint, store });
+    return store;
+}
+
+function contextIsFresh(ctx, entry) {
+    if (Date.now() - entry.checkedAt < 1000) {
+        return true;
+    }
+    entry.checkedAt = Date.now();
+    const current = createContextFingerprint(ctx, CACHE_SCHEMA);
+    return current?.fingerprint === entry.fingerprint;
+}
+
+function schedulePersist(store, delay = 250) {
+    try {
+        DIRTY_STORES.add(store);
+        if (flushTimer) {
+            clearTimeout(flushTimer);
+        }
+        flushTimer = setTimeout(() => flushStores(true), delay);
+        flushTimer.unref();
+    }
+    catch { }
+}
+
+function flushStores(retry) {
+    try {
+        if (flushTimer) {
+            clearTimeout(flushTimer);
+            flushTimer = undefined;
+        }
+        const stores = [...DIRTY_STORES];
+        DIRTY_STORES.clear();
+        for (const store of stores) {
+            const persisted = persistStore(store, CACHE_SCHEMA, isValidCacheEntry, trimEntries);
+            if (!persisted && retry && store.failures < 3) {
+                store.failures++;
+                schedulePersist(store, 1000);
+            }
+            else if (persisted) {
+                store.failures = 0;
+            }
+        }
+    }
+    catch { }
+}
+
+function trimEntries(entries) {
+    const keys = Object.keys(entries);
+    const excess = keys.length - MAX_CACHE_ENTRIES;
+    for (let index = 0; index < excess; index++) {
+        delete entries[keys[index]];
+    }
+}
+
+function isValidCacheEntry(entry) {
+    return isPlainObject(entry) && typeof entry.operation === "string" && isValidOperationValue(entry.operation, entry.value, false);
+}
+
+function isValidOperationValue(operation, value, requireWarnings) {
+    if (!isPlainObject(value) || (requireWarnings && !isWarnings(value.warnings))) {
+        return false;
+    }
+    if (operation === "getPrefix") {
+        return typeof value.prefix === "string" && typeof value.suffix === "string";
+    }
+    if (operation === "getCustomComponentClasses") {
+        return isStringArray(value.customComponentClasses);
+    }
+    if (operation === "getUnknownClasses") {
+        return isStringArray(value.unknownClasses);
+    }
+    if (operation === "getCanonicalClasses") {
+        return isPlainObject(value.canonicalClasses) && Object.values(value.canonicalClasses).every(item => isPlainObject(item) && isStringArray(item.input) && typeof item.output === "string");
+    }
+    return false;
+}
+
+function isWarnings(value) {
+    return Array.isArray(value) && value.every(item => item === undefined || item === null || isPlainObject(item));
+}
+
+function isStringArray(value) {
+    return Array.isArray(value) && value.every(item => typeof item === "string");
+}
+
+function isPlainObject(value) {
+    return value !== null && typeof value === "object" && !Array.isArray(value) && Object.getPrototypeOf(value) === Object.prototype;
+}
+
+function digest(value) {
+    return createHash("sha256").update(value).digest("hex");
+}
+
+function debug(status, operation) {
+    if (env.BETTER_TAILWINDCSS_CACHE_DEBUG === "1") {
+        console.error(`[better-tailwindcss-cache] ${status} ${operation}`);
+    }
+}
