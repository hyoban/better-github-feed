+import { createHash } from "node:crypto";
+import { existsSync, readFileSync, realpathSync, statSync } from "node:fs";
+import { dirname, isAbsolute, join, parse, resolve } from "node:path";
+import { resolveCss, resolveJs, resolveJson } from "../resolvers.js";
+
+const MAX_DEPENDENCIES = 512;
+const MAX_MEMOIZED_AGE = 1000;
+const MAX_MEMOIZED_FINGERPRINTS = 16;
+const CSS_DIRECTIVE = /@(import|reference|plugin|config)\s+(?:url\()?\s*["']([^"']+)["']/g;
+const JS_IMPORT = /(?:\b(?:import|export)\s+(?:[^"'()]*?\sfrom\s*)?|\brequire\s*\(|\bimport\s*\()\s*["']([^"']+)["']/g;
+const FINGERPRINTS = new Map();
+
+export function createMemoizedContextFingerprint(ctx, schema) {
+    const key = JSON.stringify({
+        cwd: ctx.cwd,
+        installation: ctx.installation,
+        schema,
+        tailwindConfigPath: ctx.tailwindConfigPath,
+        tsconfigPath: ctx.tsconfigPath,
+        version: ctx.version
+    });
+    const cached = FINGERPRINTS.get(key);
+    if (cached && Date.now() - cached.verifiedAt < MAX_MEMOIZED_AGE && cached.signature === dependencySignature(cached.data.dependencies)) {
+        return cached.data;
+    }
+    const data = createContextFingerprint(ctx, schema);
+    if (!data) {
+        FINGERPRINTS.delete(key);
+        return;
+    }
+    FINGERPRINTS.set(key, { data, signature: dependencySignature(data.dependencies), verifiedAt: Date.now() });
+    while (FINGERPRINTS.size > MAX_MEMOIZED_FINGERPRINTS) {
+        FINGERPRINTS.delete(FINGERPRINTS.keys().next().value);
+    }
+    return data;
+}
+
+export function createContextFingerprint(ctx, schema) {
+    try {
+        const entryPoint = ctx.tailwindConfigPath;
+        if (!entryPoint || !isAbsolute(entryPoint) || !existsSync(entryPoint)) {
+            return;
+        }
+        const hash = createHash("sha256");
+        hash.update(schema);
+        hash.update(JSON.stringify({
+            cwd: ctx.cwd,
+            installation: ctx.installation,
+            tsconfigPath: ctx.tsconfigPath,
+            version: ctx.version
+        }));
