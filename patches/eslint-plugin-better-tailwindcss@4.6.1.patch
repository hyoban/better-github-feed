+    if (!existsSync(normalized)) {
+        return;
+    }
+    return realpathSync(normalized);
+}
+
+function stripQueryAndFragment(value) {
+    return value.replace(/[?#].*$/, "");
+}
+
+function isRemote(value) {
+    return /^(?:data:|https?:|\/\/)/.test(value);
+}
